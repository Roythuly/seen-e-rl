{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/v0/backend_spec.schema.json",
  "title": "BackendSpec",
  "description": "Minimum contract for selecting the primary training or inference backend.",
  "type": "object",
  "x-status": "minimum",
  "required": ["name", "runtime_mode"],
  "properties": {
    "name": {
      "type": "string",
      "enum": ["torch", "jax"]
    },
    "runtime_mode": {
      "type": "string",
      "enum": ["train", "infer", "mixed"]
    },
    "device": {
      "type": "string"
    },
    "compatibility_tier": {
      "type": "string",
      "enum": ["primary", "compatible"]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
