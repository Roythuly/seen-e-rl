{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/v0/policy_snapshot.schema.json",
  "title": "PolicySnapshot",
  "description": "Minimum contract for a published inference-time actor snapshot.",
  "type": "object",
  "x-status": "minimum",
  "required": ["run_id", "policy_version", "actor_ref", "published_at", "backend", "algorithm", "checkpoint_id"],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "policy_version": {
      "type": "integer"
    },
    "actor_ref": {
      "type": "string"
    },
    "published_at": {
      "type": "string"
    },
    "backend": {
      "type": "string"
    },
    "algorithm": {
      "type": "string"
    },
    "checkpoint_id": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}
