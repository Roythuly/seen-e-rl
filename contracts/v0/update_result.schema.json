{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/v0/update_result.schema.json",
  "title": "UpdateResult",
  "description": "Minimum contract for algorithm update outputs.",
  "type": "object",
  "x-status": "minimum",
  "required": ["run_id", "policy_version", "env_steps", "grad_steps", "status", "published_policy", "metrics"],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "policy_version": {
      "type": "integer"
    },
    "checkpoint_id": {
      "type": ["string", "null"]
    },
    "env_steps": {
      "type": "integer"
    },
    "grad_steps": {
      "type": "integer"
    },
    "status": {
      "type": "string"
    },
    "published_policy": {
      "type": "boolean"
    },
    "metrics": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
