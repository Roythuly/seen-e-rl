{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/v0/collection_schedule.schema.json",
  "title": "CollectionSchedule",
  "description": "Minimum contract for deciding how runtime collects trajectories or transitions.",
  "type": "object",
  "x-status": "minimum",
  "required": ["mode", "unit", "amount", "freeze_policy_during_collection"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["step", "trajectory", "episode", "rollout"]
    },
    "unit": {
      "type": "string",
      "enum": ["env_step", "trajectory", "episode", "rollout"]
    },
    "amount": {
      "type": "integer"
    },
    "freeze_policy_during_collection": {
      "type": "boolean"
    },
    "warmup_env_steps": {
      "type": "integer"
    }
  },
  "additionalProperties": true
}
