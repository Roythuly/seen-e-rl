{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/v0/replay_buffer_spec.schema.json",
  "title": "ReplayBufferSpec",
  "description": "Minimum contract for replay buffer capacity and sampling settings.",
  "type": "object",
  "x-status": "minimum",
  "required": ["capacity", "batch_size", "min_ready_size", "sampling_mode"],
  "properties": {
    "capacity": {
      "type": "integer"
    },
    "batch_size": {
      "type": "integer"
    },
    "min_ready_size": {
      "type": "integer"
    },
    "sampling_mode": {
      "type": "string",
      "enum": ["random", "prioritized", "fifo"]
    }
  },
  "additionalProperties": true
}
